# ═══════════════════════════════════════════════════════════
# Glastonbury Terminal — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ─── Alpaca Trading API ────────────────────────────────────
# Get your keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# ─── Financial Modeling Prep (FMP) ─────────────────────────
# Get your key at https://site.financialmodelingprep.com/developer/docs
# Free tier: 250 requests/day
FMP_API_KEY=your_fmp_api_key

# ─── Supabase ──────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Anthropic Claude AI (Keisha) ──────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Finnhub ──────────────────────────────────────────────
# Get your key at https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_api_key

# ─── App Security ──────────────────────────────────────────
# Password for the login gate
APP_PASSWORD=your_login_password

# ─── Cron / Scheduled Tasks ───────────────────────────────
# Secret token for authenticating scheduled API calls (briefing, snapshots)
# Pass as Bearer token or x-api-key header
CRON_SECRET=your_cron_secret_here

# ─── App URL (optional) ───────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
