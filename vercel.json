{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://terminal.johnwesleyhicks.com"
  },
  "crons": [
    {
      "_comment_morning_push": "6:30 AM EDT — lightweight zero-latency push (no Claude)",
      "path": "/api/briefing/morning-push",
      "schedule": "30 10 * * 1-5"
    },
    {
      "_comment_briefing": "9:30 AM EDT — full Claude-powered deep briefing (was 6:30 AM, moved to give morning-push the prime slot)",
      "path": "/api/briefing/scheduled",
      "schedule": "30 13 * * 1-5"
    },
    {
      "_comment_weekly_report": "Sunday 7 PM EDT — F13 weekly summary email (NW delta, trade indicators, prediction markets)",
      "path": "/api/cron/weekly-report",
      "schedule": "0 23 * * 0"
    },
    {
      "path": "/api/portfolio/snapshot",
      "schedule": "0 22 * * 1-5"
    },
    {
      "path": "/api/cron/storm-watch",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/tax-harvest",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/coach-review",
      "schedule": "0 1 * * 1"
    },
    {
      "path": "/api/cron/prediction-snapshot",
      "schedule": "0 13 * * *"
    }
  ]
}
