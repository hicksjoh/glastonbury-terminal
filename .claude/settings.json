{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(e2e/**)",
      "Write(docs/**)",
      "Write(memory/**)",
      "Write(supabase/migrations/**)",
      "Write(scripts/**)",
      "Write(public/**)",
      "Write(.claude/**)",
      "Edit(src/**)",
      "Edit(e2e/**)",
      "Edit(docs/**)",
      "Edit(memory/**)",
      "Edit(scripts/**)",
      "Edit(public/**)",
      "Edit(.claude/**)",
      "Edit(package.json)",
      "Edit(package-lock.json)",
      "Edit(tailwind.config.ts)",
      "Edit(tsconfig.json)",
      "Edit(next.config.js)",
      "Edit(vercel.json)",
      "Edit(playwright.config.ts)",
      "Edit(CLAUDE.md)",
      "Bash(npm install*)",
      "Bash(npm run build)",
      "Bash(npm run dev*)",
      "Bash(npm run lint*)",
      "Bash(npm run start)",
      "Bash(npm run test*)",
      "Bash(npx playwright test*)",
      "Bash(npx playwright install*)",
      "Bash(npx tsc*)",
      "Bash(npx prettier*)",
      "Bash(npx vitest*)",
      "Bash(node scripts/*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git worktree*)",
      "Bash(git restore*)",
      "Bash(gh pr*)",
      "Bash(gh issue*)",
      "Bash(gh api*)",
      "Bash(gh run*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(pwd)",
      "Bash(which*)",
      "Bash(mkdir -p*)",
      "Bash(touch*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(echo*)",
      "Bash(find*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(jq*)",
      "Bash(curl*)",
      "Bash(supabase migration*)",
      "Bash(supabase db diff*)",
      "Bash(supabase gen types*)",
      "Bash(vercel env*)",
      "Bash(vercel logs*)",
      "Bash(vercel inspect*)",
      "Bash(claude --worktree*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Edit(.env*)",
      "Write(.env*)",
      "Edit(.env.local)",
      "Write(.env.local)",
      "Edit(.env.production)",
      "Write(.env.production)",
      "Edit(supabase/schema.sql)",
      "Edit(middleware.ts)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push origin +*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D*)",
      "Bash(sudo*)",
      "Bash(npm publish*)",
      "Bash(supabase db reset*)",
      "Bash(supabase db push --force*)",
      "Bash(vercel --prod --force*)",
      "Bash(vercel rollback*)",
      "Bash(vercel remove*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/claude-hook-block-secrets.mjs"
          }
        ]
      }
    ]
  }
}
